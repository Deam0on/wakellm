
# WakeLLM environment configuration (example)
#
# Usage (Docker):
#   docker run --env-file env/config.env ... wakellm:latest start
#
# Usage (Linux shell):
#   set -a; source env/config.env; set +a
#   python3 -m wakellm start

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# RunPod API key (Account -> API Keys)
WAKELLM_RUNPOD_API_KEY="YOUR_RUNPOD_API_KEY"

# RunPod pod id (e.g. 6068y77xfq1rux)
WAKELLM_RUNPOD_POD_ID="YOUR_POD_ID"

# One of the following SSH key options is required:
# Option A: path to an SSH private key file (recommended)
# For Docker, bind-mount your host key into the container, e.g.:
#   -v /home/pi/.ssh/id_ed25519:/run/secrets/id_ed25519:ro
WAKELLM_SSH_KEY_PATH="/run/secrets/id_ed25519"

# Option B: raw SSH private key content (multi-line). Prefer WAKELLM_SSH_KEY_PATH.
# WAKELLM_SSH_KEY='-----BEGIN OPENSSH PRIVATE KEY-----
# ...
# -----END OPENSSH PRIVATE KEY-----'

# Port forwarding rules (comma-separated local:remote)
WAKELLM_PORTS="11434:11434,8080:8080"

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# Startup behaviour
# WAKELLM_STARTUP_TIMEOUT=5
# WAKELLM_STARTUP_BOOT_WAIT=10

# Idle auto-kill
# WAKELLM_AUTOKILL_IDLE=15
# WAKELLM_AUTOKILL_HARD=120
# WAKELLM_AUTOKILL_POLL=30
# WAKELLM_AUTOKILL_OLLAMA_PORT=11434

# Local HTTP API
# WAKELLM_API_ENABLED=true
# WAKELLM_API_HOST=127.0.0.1
# WAKELLM_API_PORT=8765
